---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ProfileCard from "@/components/bento/ProfileCard.astro";
import GreetingCard from "@/components/bento/GreetingCard.astro";
import LatestPostsCard from "@/components/bento/LatestPostsCard.astro";
import RandomPickCard from "@/components/bento/RandomPickCard.astro";
import ClockCard from "@/components/bento/ClockCard.astro";
import CalendarCard from "@/components/bento/CalendarCard.astro";
import GithubCard from "@/components/bento/GithubCard.astro";
import SocialsCard from "@/components/bento/SocialsCard.astro";
import CollageCard from "@/components/bento/CollageCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { collapseRecent, SERIES, firstTagSlug } from "@/utils/postSeries";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

// Latest list with any multi-part series folded into a single entry, so a
// 39-chapter book doesn't bury everything else.
const latest = collapseRecent(sortedPosts, 4);
// Daily recommendation draws from standalone posts (not series chapters).
const pickPool = sortedPosts.filter(p => !SERIES[firstTagSlug(p)]);

/* Calendar: posts published in the current month (site timezone) */
const dayFmt = new Intl.DateTimeFormat("en-CA", { timeZone: SITE.timezone });
const [calYear, calMonth, calToday] = dayFmt
  .format(new Date())
  .split("-")
  .map(Number);

const postsByDay: Record<number, { title: string; path: string }[]> = {};
for (const post of sortedPosts) {
  const [py, pm, pd] = dayFmt
    .format(new Date(post.data.pubDatetime))
    .split("-")
    .map(Number);
  if (py === calYear && pm === calMonth) {
    (postsByDay[pd] ??= []).push({
      title: post.data.title,
      path: getPath(post.id, post.filePath),
    });
  }
}
---

<Layout>
  <Header minimal />

  <main id="main-content" data-layout="index" class="app-layout-wide pt-4 pb-14 sm:pt-6">
    <h1 class="sr-only">{SITE.title} — {SITE.desc}</h1>

    <div class="bento-grid grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-12">
      <div class="bento-item sm:col-span-2 lg:col-span-5 lg:col-start-4 lg:row-start-1" style="--i: 0">
        <GreetingCard />
      </div>

      <div class="bento-item lg:col-span-3 lg:col-start-1 lg:row-span-2 lg:row-start-1" style="--i: 1">
        <ProfileCard />
      </div>

      <div class="bento-item lg:col-span-4 lg:col-start-9 lg:row-start-1" style="--i: 2">
        <ClockCard />
      </div>

      <div class="bento-item sm:col-span-2 lg:col-span-5 lg:col-start-4 lg:row-start-2" style="--i: 3">
        <LatestPostsCard entries={latest} />
      </div>

      <div class="bento-item lg:col-span-4 lg:col-start-9 lg:row-start-2" style="--i: 4">
        <CalendarCard
          year={calYear}
          month={calMonth}
          today={calToday}
          postsByDay={postsByDay}
        />
      </div>

      <div class="bento-item lg:col-span-4" style="--i: 5">
        <RandomPickCard candidates={pickPool} />
      </div>

      <div class="bento-item sm:col-span-2 lg:col-span-5" style="--i: 6">
        <GithubCard />
      </div>

      <div class="bento-item flex items-center justify-center lg:col-span-3" style="--i: 7">
        <SocialsCard />
      </div>

      <div class="bento-item sm:col-span-2 lg:col-span-12" style="--i: 8">
        <CollageCard />
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* Staggered entrance: cards rise in one after another on first paint */
  .bento-item {
    animation: bento-enter 0.55s cubic-bezier(0.22, 0.9, 0.3, 1) both;
    animation-delay: calc(var(--i, 0) * 70ms);
  }

  @keyframes bento-enter {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Quiet card physics: lift on hover, settle on press */
  .bento-item > :global(.bento-card) {
    height: 100%;
    transition:
      transform 0.25s cubic-bezier(0.22, 0.9, 0.3, 1),
      box-shadow 0.25s ease;
  }

  @media (hover: hover) {
    .bento-item > :global(.bento-card:hover) {
      transform: translateY(-2px);
      box-shadow: var(--shadow-float);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-item {
      animation: none;
    }
    .bento-item > :global(.bento-card),
    .bento-item > :global(.bento-card:hover) {
      transform: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
