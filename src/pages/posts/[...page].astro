---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import "@pagefind/default-ui/css/ui.css";
import getSortedPosts from "@/utils/getSortedPosts";
import { buildFolders, collapseRecent, SERIES } from "@/utils/postSeries";
import { SITE } from "@/config";

// Single-page file-tree index — no pagination.
export const getStaticPaths = (() => {
  return [{ params: { page: undefined } }];
}) satisfies GetStaticPaths;

function fmtMonthDay(d: Date): string {
  return `${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
}

function fmtDate(d: Date): string {
  return `${d.getFullYear()}-${fmtMonthDay(d)}`;
}

const sortedPosts = getSortedPosts(await getCollection("blog"));
const totalPosts = sortedPosts.length;

const folders = buildFolders(sortedPosts);
const recent = collapseRecent(sortedPosts, 5);

// How many chapter/post rows to show before an expanded folder truncates.
const VISIBLE = 6;
---

<Layout
  title={`文章 | ${SITE.title}`}
  description={`${SITE.title} 的所有文章，用檔案樹依分類與系列整理`}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-10">
    <!-- Hero -->
    <div class="mb-7">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">文章</h1>
      <p class="mt-2 text-sm text-ink-muted">
        {totalPosts} 篇文章 · {folders.length} 個分類 · 點資料夾展開
      </p>
    </div>

    <!-- Search -->
    <div class="posts-toolbar mb-7">
      <div class="posts-search-wrapper">
        <div id="posts-pagefind" class="premium-search"></div>
      </div>
    </div>

    <!-- Default view: collapsed-recent strip + file tree -->
    <div data-default-posts-container class="w-full">
      <!-- Recent strip (series collapsed to one line) -->
      <section class="recent-strip" aria-label="最近更新">
        <header class="strip-header">
          <span class="strip-marker">$</span>
          <span class="strip-label">recent</span>
          <span class="strip-divider"></span>
        </header>
        <ol class="recent-list">
          {
            recent.map(entry =>
              entry.kind === "series" ? (
                <li class="recent-item">
                  <a href={entry.href} class="recent-link">
                    <time class="recent-date">{fmtDate(entry.date)}</time>
                    <span class="recent-title">{entry.name}</span>
                    <span class="recent-badge">系列 · {entry.count} 篇</span>
                  </a>
                </li>
              ) : (
                <li class="recent-item">
                  <a
                    href={entry.href}
                    class="recent-link"
                    data-post-path={entry.href}
                  >
                    <time class="recent-date">{fmtDate(entry.date)}</time>
                    <span class="recent-title">{entry.title}</span>
                    <span class="read-mark" title="看過了" aria-label="已閱讀">
                      ✓
                    </span>
                  </a>
                </li>
              )
            )
          }
        </ol>
      </section>

      <!-- File tree -->
      <section class="tree" aria-label="依分類瀏覽" data-tree>
        <div class="tree-root">
          <span class="root-caret" aria-hidden="true">▾</span>
          <span class="root-name">posts/</span>
          <span class="root-meta">
            {totalPosts} posts · {folders.length} folders
          </span>
        </div>

        {
          folders.map((folder, i) => {
            const shown = folder.entries.slice(0, VISIBLE);
            const more = folder.entries.length - shown.length;
            const seeAll = SERIES[folder.slug]?.landing ?? `/tags/${folder.slug}`;
            return (
              <details
                class="tree-folder"
                open={i === 0}
                data-folder={folder.slug}
              >
                <summary class="folder-row">
                  <span class="caret" aria-hidden="true">
                    ▸
                  </span>
                  <span class="folder-name">{folder.slug}/</span>
                  <span class="folder-count">({folder.count})</span>
                  {folder.isSeries && <span class="folder-badge">系列</span>}
                  <span class="folder-date">{fmtMonthDay(folder.latest)}</span>
                </summary>
                <div class="folder-body">
                  {folder.landing && (
                    <a href={folder.landing.href} class="file-row file-landing">
                      <span class="file-dot" aria-hidden="true">
                        ●
                      </span>
                      <span class="file-title">{folder.landing.title}</span>
                    </a>
                  )}
                  {shown.map(entry => (
                    <a
                      href={entry.href}
                      class="file-row"
                      data-post-path={entry.href}
                    >
                      <span class="file-title">{entry.title}</span>
                      <span class="read-mark" title="看過了" aria-label="已閱讀">
                        ✓
                      </span>
                      <time class="file-date">{fmtMonthDay(entry.date)}</time>
                    </a>
                  ))}
                  {more > 0 && (
                    <a href={seeAll} class="file-more">
                      … {more} more →
                    </a>
                  )}
                </div>
              </details>
            );
          })
        }
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { pagefindTranslations } from "@/utils/pagefindTranslations";

  let cleanupController: AbortController | null = null;

  const TREE_KEY = "postsTreeOpen";

  function restoreTreeState() {
    const tree = document.querySelector("[data-tree]");
    if (!tree) return;
    let open: string[] | null = null;
    try {
      const raw = sessionStorage.getItem(TREE_KEY);
      if (raw) open = JSON.parse(raw);
    } catch {
      open = null;
    }
    // Only override the server default once the visitor has toggled something.
    if (!open) return;
    tree.querySelectorAll<HTMLDetailsElement>(".tree-folder").forEach(d => {
      const slug = d.dataset.folder ?? "";
      d.open = open!.includes(slug);
    });
  }

  function persistTreeState() {
    const tree = document.querySelector("[data-tree]");
    if (!tree) return;
    const open: string[] = [];
    tree.querySelectorAll<HTMLDetailsElement>(".tree-folder").forEach(d => {
      if (d.open) open.push(d.dataset.folder ?? "");
    });
    try {
      sessionStorage.setItem(TREE_KEY, JSON.stringify(open));
    } catch {
      /* ignore quota / private-mode errors */
    }
  }

  function applyReadMarks() {
    let read: string[] = [];
    try {
      read = JSON.parse(localStorage.getItem("readPosts") ?? "[]");
    } catch {
      read = [];
    }
    if (read.length === 0) return;
    document.querySelectorAll<HTMLElement>("[data-post-path]").forEach(link => {
      if (read.includes(link.dataset.postPath ?? "")) {
        link.querySelector(".read-mark")?.classList.add("is-read");
      }
    });
  }

  function initPostsPage() {
    if (cleanupController) cleanupController.abort();
    cleanupController = new AbortController();
    const { signal } = cleanupController;

    restoreTreeState();
    applyReadMarks();

    // Save expand/collapse state whenever a folder toggles.
    document
      .querySelectorAll<HTMLDetailsElement>("[data-tree] .tree-folder")
      .forEach(d => {
        d.addEventListener("toggle", persistTreeState, { signal });
      });

    // Pagefind local search
    const container = document.querySelector("#posts-pagefind");
    if (!container || container.childElementCount > 0) return;

    const onIdle = window.requestIdleCallback || (cb => setTimeout(cb, 1));
    onIdle(async () => {
      if (signal.aborted) return;
      if (container.childElementCount > 0) return;

      // @ts-expect-error
      const { PagefindUI } = await import("@pagefind/default-ui");

      if (signal.aborted || container.childElementCount > 0) return;

      if (import.meta.env.DEV) {
        container.innerHTML = `
          <div class="bg-muted/75 rounded p-4 text-sm mb-4 border border-border">
            <p><strong>Dev Mode:</strong> Search will try to use the most recently built index. If you don't see results, run <code>pnpm run build</code> first.</p>
          </div>
        `;
      }

      new PagefindUI({
        element: "#posts-pagefind",
        showImages: false,
        showSubResults: true,
        translations: pagefindTranslations,
      });

      const input = container.querySelector(
        ".pagefind-ui__search-input"
      ) as HTMLInputElement;
      const defaultContainer = document.querySelector(
        "[data-default-posts-container]"
      ) as HTMLElement;

      if (input && defaultContainer) {
        const toggleVisibility = () => {
          const hasValue = input.value.trim().length > 0;
          defaultContainer.style.display = hasValue ? "none" : "";
        };

        input.addEventListener("input", toggleVisibility, { signal });

        const clearBtn = container.querySelector(".pagefind-ui__search-clear");
        if (clearBtn) {
          clearBtn.addEventListener(
            "click",
            () => requestAnimationFrame(() => toggleVisibility()),
            { signal }
          );
        }
      }

      const handleCmdK = (e: KeyboardEvent) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          e.stopPropagation();
          if (input) {
            input.focus();
            input.scrollIntoView({ behavior: "smooth", block: "center" });
          }
        }
      };
      document.addEventListener("keydown", handleCmdK, {
        signal,
        capture: true,
      });
    });
  }

  document.addEventListener("astro:page-load", initPostsPage);
</script>

<style>
  /* ─── Toolbar ─── */
  .posts-toolbar {
    position: relative;
    z-index: 20;
  }

  /* ─── Recent strip ─── */
  .recent-strip {
    margin-bottom: 2.5rem;
  }
  .strip-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-cartograph), monospace;
    font-size: 0.85rem;
  }
  .strip-marker {
    color: var(--accent);
    font-weight: 700;
  }
  .strip-label {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }
  .strip-divider {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--border) 50%, transparent),
      transparent
    );
  }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .recent-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.5rem;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .recent-link:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .recent-link:hover .recent-title {
    color: var(--accent);
  }
  .recent-date {
    font-family: var(--font-cartograph), monospace;
    font-size: 0.8rem;
    color: var(--ink-muted);
    flex-shrink: 0;
    min-width: 6.5em;
  }
  .recent-title {
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--foreground);
    transition: color 0.15s ease;
  }
  .recent-badge {
    flex-shrink: 0;
    font-family: var(--font-cartograph), monospace;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--accent);
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    align-self: center;
  }

  /* ─── File tree ─── */
  .tree {
    font-family: var(--font-cartograph), monospace;
  }

  .tree-root {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.25rem 0.1rem 0.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    margin-bottom: 0.4rem;
  }
  .root-caret {
    color: var(--accent);
  }
  .root-name {
    font-weight: 700;
    color: var(--foreground);
  }
  .root-meta {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--ink-faint);
  }

  .tree-folder {
    border-radius: 0.4rem;
  }

  .folder-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.5rem;
    border-radius: 0.45rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.15s ease;
  }
  .folder-row::-webkit-details-marker {
    display: none;
  }
  .folder-row:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .caret {
    display: inline-block;
    color: var(--accent);
    font-size: 0.7rem;
    transition: transform 0.18s ease;
    flex-shrink: 0;
    width: 0.8em;
  }
  .tree-folder[open] > .folder-row .caret {
    transform: rotate(90deg);
  }
  .folder-name {
    color: var(--foreground);
    font-weight: 600;
  }
  .folder-row:hover .folder-name {
    color: var(--accent);
  }
  .folder-count {
    color: var(--ink-muted);
    font-size: 0.82rem;
  }
  .folder-badge {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--accent);
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .folder-date {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--ink-faint);
    flex-shrink: 0;
  }

  /* Folder contents: guide rail + branch ticks */
  .folder-body {
    margin-left: 1.15rem;
    padding-left: 0.9rem;
    border-left: 1px solid color-mix(in srgb, var(--border) 45%, transparent);
    padding-bottom: 0.35rem;
  }

  .file-row {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.32rem 0.45rem;
    border-radius: 0.35rem;
    transition: background 0.15s ease;
  }
  .file-row::before {
    content: "";
    position: absolute;
    left: -0.9rem;
    top: 0.85em;
    width: 0.62rem;
    height: 1px;
    background: color-mix(in srgb, var(--border) 55%, transparent);
  }
  .file-row:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .file-title {
    flex: 1;
    min-width: 0;
    font-family: var(--font-app);
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--ink-secondary);
    transition: color 0.15s ease;
    word-break: break-word;
  }
  .file-row:hover .file-title {
    color: var(--accent);
  }
  .file-date {
    flex-shrink: 0;
    font-size: 0.72rem;
    color: var(--ink-faint);
  }
  .file-dot {
    color: var(--accent);
    font-size: 0.5rem;
    line-height: 1;
    align-self: center;
  }
  .file-landing .file-title {
    font-weight: 600;
    color: var(--foreground);
  }

  .file-more {
    position: relative;
    display: inline-flex;
    margin-top: 0.15rem;
    padding: 0.3rem 0.45rem;
    font-size: 0.78rem;
    color: var(--ink-muted);
    border-radius: 0.35rem;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .file-more::before {
    content: "";
    position: absolute;
    left: -0.9rem;
    top: 0.95em;
    width: 0.62rem;
    height: 1px;
    background: color-mix(in srgb, var(--border) 55%, transparent);
  }
  .file-more:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  /* Read marks (revealed by JS when a post has been opened) */
  .read-mark {
    flex-shrink: 0;
    display: none;
    font-size: 0.75rem;
    color: var(--sticker-green);
    align-self: center;
  }
  .read-mark.is-read {
    display: inline;
  }
</style>
