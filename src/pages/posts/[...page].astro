---
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import "@pagefind/default-ui/css/ui.css";
import getSortedPosts from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

// Single-page categorized index — no pagination.
export const getStaticPaths = (() => {
  return [{ params: { page: undefined } }];
}) satisfies GetStaticPaths;

const TAG_DISPLAY: Record<string, string> = {
  "hermes-from-zero": "Hermes From Zero",
  leetcode: "LeetCode",
  linux: "Linux",
  linux_kernel: "Linux Kernel",
  c: "C",
  go: "Go",
  docker: "Docker",
  concurrency: "Concurrency",
  network: "Networking",
  paper: "Paper",
  ai: "AI / LLM",
  ironman: "Ironman",
  agent: "Agent",
  llm: "LLM",
  container: "Container",
  kernel: "Kernel",
  ebpf: "eBPF",
  github: "GitHub",
};

function displayTag(slug: string): string {
  if (TAG_DISPLAY[slug]) return TAG_DISPLAY[slug];
  return slug
    .split(/[-_]/)
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

function fmtMonthDay(d: string | Date): string {
  const date = new Date(d);
  return `${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
}

function fmtDate(d: string | Date): string {
  const date = new Date(d);
  return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
}

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(allPosts);
const totalPosts = sortedPosts.length;

// Group by FIRST tag (primary tag)
const buckets = new Map<string, CollectionEntry<"blog">[]>();
for (const post of sortedPosts) {
  const firstTag = post.data.tags?.[0] ?? "misc";
  const slug = slugifyStr(firstTag);
  if (!buckets.has(slug)) buckets.set(slug, []);
  buckets.get(slug)!.push(post);
}

// Sort: by post count desc, then alphabetical for ties
const sortedBuckets = [...buckets.entries()].sort((a, b) => {
  if (b[1].length !== a[1].length) return b[1].length - a[1].length;
  return a[0].localeCompare(b[0]);
});

const TOP_N = 5;
const RECENT_N = 4;
const recentPosts = sortedPosts.slice(0, RECENT_N);
---

<Layout title={`文章 | ${SITE.title}`} description={`${SITE.title} 的所有文章，依分類整理`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-8">
    <!-- Hero -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">文章</h1>
      <p class="mt-2 text-ink-muted">
        {totalPosts} 篇文章 · {sortedBuckets.length} 個分類
      </p>
    </div>

    <!-- Search -->
    <div class="posts-toolbar mb-8">
      <div class="posts-search-wrapper">
        <div id="posts-pagefind" class="premium-search"></div>
      </div>
    </div>

    <!-- Default view: recent strip + categorized buckets -->
    <div data-default-posts-container class="w-full">
      <!-- Recent strip -->
      <section class="recent-strip" aria-label="Recent posts">
        <header class="strip-header">
          <span class="strip-marker">$</span>
          <span class="strip-label">recent</span>
          <span class="strip-divider"></span>
        </header>
        <ol class="recent-list">
          {
            recentPosts.map(post => (
              <li class="recent-item">
                <a href={getPath(post.id, post.filePath)} class="recent-link">
                  <time class="recent-date" datetime={String(post.data.pubDatetime)}>
                    {fmtDate(post.data.pubDatetime)}
                  </time>
                  <span class="recent-title">{post.data.title}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- Category buckets -->
      <section class="buckets-grid" aria-label="By category">
        {
          sortedBuckets.map(([tagSlug, posts]) => {
            const top = posts.slice(0, TOP_N);
            const remaining = posts.length - top.length;
            const tagHref = `/tags/${tagSlug}`;
            return (
              <article class="bucket">
                <header class="bucket-header">
                  <h2 class="bucket-title">
                    <span class="bucket-marker">▸</span>
                    <a href={tagHref} class="bucket-title-link">
                      {displayTag(tagSlug)}
                    </a>
                    <span class="bucket-count">({posts.length})</span>
                  </h2>
                  {remaining > 0 && (
                    <a href={tagHref} class="bucket-see-all">
                      see all →
                    </a>
                  )}
                </header>
                <ol class="bucket-list">
                  {top.map(post => (
                    <li class="bucket-item">
                      <a
                        href={getPath(post.id, post.filePath)}
                        class="bucket-link"
                      >
                        <time
                          class="bucket-date"
                          datetime={String(post.data.pubDatetime)}
                        >
                          {fmtMonthDay(post.data.pubDatetime)}
                        </time>
                        <span class="bucket-post-title">{post.data.title}</span>
                      </a>
                    </li>
                  ))}
                </ol>
                {remaining > 0 && (
                  <a href={tagHref} class="bucket-more">
                    + {remaining} more
                  </a>
                )}
              </article>
            );
          })
        }
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  let cleanupController: AbortController | null = null;

  function initPostsPage() {
    if (cleanupController) cleanupController.abort();
    cleanupController = new AbortController();
    const { signal } = cleanupController;

    // Initialize Pagefind local search
    const container = document.querySelector("#posts-pagefind");
    if (!container || container.childElementCount > 0) return;

    const onIdle = window.requestIdleCallback || (cb => setTimeout(cb, 1));
    onIdle(async () => {
      if (signal.aborted) return;
      if (container.childElementCount > 0) return;

      // @ts-expect-error
      const { PagefindUI } = await import("@pagefind/default-ui");

      if (signal.aborted || container.childElementCount > 0) return;

      if (import.meta.env.DEV) {
        container.innerHTML = `
          <div class="bg-muted/75 rounded p-4 text-sm mb-4 border border-border">
            <p><strong>Dev Mode:</strong> Search will try to use the most recently built index. If you don't see results, run <code>pnpm run build</code> first.</p>
          </div>
        `;
      }

      new PagefindUI({
        element: "#posts-pagefind",
        showImages: false,
        showSubResults: true,
      });

      const input = container.querySelector(
        ".pagefind-ui__search-input"
      ) as HTMLInputElement;
      const defaultContainer = document.querySelector(
        "[data-default-posts-container]"
      ) as HTMLElement;

      if (input && defaultContainer) {
        const toggleVisibility = () => {
          const hasValue = input.value.trim().length > 0;
          if (hasValue) {
            defaultContainer.style.display = "none";
          } else {
            defaultContainer.style.display = "";
          }
        };

        input.addEventListener("input", toggleVisibility, { signal });

        const clearBtn = container.querySelector(".pagefind-ui__search-clear");
        if (clearBtn) {
          clearBtn.addEventListener(
            "click",
            () => {
              requestAnimationFrame(() => toggleVisibility());
            },
            { signal }
          );
        }
      }

      const handleCmdK = (e: KeyboardEvent) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          e.stopPropagation();
          if (input) {
            input.focus();
            input.scrollIntoView({ behavior: "smooth", block: "center" });
          }
        }
      };
      document.addEventListener("keydown", handleCmdK, {
        signal,
        capture: true,
      });
    });
  }

  document.addEventListener("astro:page-load", initPostsPage);
</script>

<style>
  /* ─── Toolbar ─── */
  .posts-toolbar {
    position: relative;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ─── Recent strip ─── */
  .recent-strip {
    margin-bottom: 3rem;
  }
  .strip-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-cartograph), monospace;
    font-size: 0.85rem;
  }
  .strip-marker {
    color: var(--accent);
    font-weight: 700;
  }
  .strip-label {
    color: var(--ink-muted);
    letter-spacing: 0.05em;
  }
  .strip-divider {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--border) 50%, transparent),
      transparent
    );
  }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .recent-item {
    margin: 0;
  }
  .recent-link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0.75rem;
    border-radius: 0.5rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .recent-link:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .recent-link:hover .recent-title {
    color: var(--accent);
  }
  .recent-date {
    font-family: var(--font-cartograph), monospace;
    font-size: 0.8rem;
    color: var(--ink-muted);
    flex-shrink: 0;
    min-width: 6.5em;
  }
  .recent-title {
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--foreground);
    transition: color 0.15s ease;
  }

  /* ─── Buckets grid ─── */
  .buckets-grid {
    display: grid;
    gap: 1.75rem 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .buckets-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2.5rem;
    }
  }

  .bucket {
    position: relative;
  }

  .bucket-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid
      color-mix(in srgb, var(--border) 40%, transparent);
  }

  .bucket-title {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-cartograph), monospace;
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .bucket-marker {
    color: var(--accent);
    transition: transform 0.2s ease;
  }
  .bucket:hover .bucket-marker {
    transform: translateX(2px);
  }

  .bucket-title-link {
    color: var(--foreground);
    transition: color 0.15s ease;
  }
  .bucket-title-link:hover {
    color: var(--accent);
  }

  .bucket-count {
    color: var(--ink-muted);
    font-weight: 400;
    font-size: 0.85rem;
  }

  .bucket-see-all {
    font-family: var(--font-cartograph), monospace;
    font-size: 0.75rem;
    color: var(--ink-muted);
    opacity: 0.6;
    transition: opacity 0.15s ease, color 0.15s ease;
  }
  .bucket:hover .bucket-see-all,
  .bucket-see-all:hover {
    opacity: 1;
    color: var(--accent);
  }

  .bucket-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .bucket-item {
    margin: 0;
  }

  .bucket-link {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.4rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .bucket-link:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .bucket-link:hover .bucket-post-title {
    color: var(--accent);
  }

  .bucket-date {
    font-family: var(--font-cartograph), monospace;
    font-size: 0.75rem;
    color: var(--ink-muted);
    flex-shrink: 0;
    min-width: 3.1em;
    letter-spacing: 0.02em;
  }

  .bucket-post-title {
    font-size: 0.9rem;
    line-height: 1.35;
    color: var(--foreground);
    transition: color 0.15s ease;
    /* Allow wrapping but keep tight */
    word-break: break-word;
  }

  .bucket-more {
    display: inline-block;
    margin-top: 0.4rem;
    margin-left: 0.5rem;
    font-family: var(--font-cartograph), monospace;
    font-size: 0.75rem;
    color: var(--ink-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 0.3rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .bucket-more:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
</style>
