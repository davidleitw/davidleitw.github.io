---
import type { SeriesContext } from "@/utils/series";

type Props = { ctx: SeriesContext };

const { ctx } = Astro.props;
const { series, position, partTitle, parts, isLanding } = ctx;
---

<nav
  class="series-nav"
  aria-label={`${series.name} 系列導覽`}
  data-series-nav
  data-total={series.total}
  data-pagefind-ignore
>
  <div class="series-bar">
    <a href={series.landing} class="series-home">
      <svg
        class="series-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M4 5.5A1.5 1.5 0 0 1 5.5 4H19v14H5.5A1.5 1.5 0 0 0 4 19.5Z"
        ></path>
        <path d="M4 19.5A1.5 1.5 0 0 1 5.5 18H19v2.5H5.5A1.5 1.5 0 0 1 4 19.5Z"
        ></path>
      </svg>
      <span class="series-title">{series.shortName}</span>
    </a>

    {partTitle && <span class="series-part">{partTitle}</span>}

    {
      position !== null && (
        <span class="series-pos">
          {position} <span class="series-pos-sep">/</span> {series.total}
        </span>
      )
    }

    <details class="series-toc" data-series-toc>
      <summary class="toc-button">
        <svg
          class="toc-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="8" y1="6" x2="20" y2="6"></line>
          <line x1="8" y1="12" x2="20" y2="12"></line>
          <line x1="8" y1="18" x2="20" y2="18"></line>
          <line x1="4" y1="6" x2="4" y2="6"></line>
          <line x1="4" y1="12" x2="4" y2="12"></line>
          <line x1="4" y1="18" x2="4" y2="18"></line>
        </svg>
        <span class="toc-open-label">目錄</span>
        <span class="toc-close-label">關閉</span>
        <span class="toc-progress" data-series-progress hidden></span>
      </summary>

      <div class="toc-panel">
        <a
          href={series.landing}
          class:list={["toc-row", "toc-landing", { "is-current": isLanding }]}
          aria-current={isLanding ? "page" : undefined}
        >
          {series.landingLabel}
        </a>

        {
          parts.map(part => (
            <section class="toc-part">
              {part.title && <h2 class="toc-part-title">{part.title}</h2>}
              {part.entries.map(entry => (
                <a
                  href={entry.href}
                  class:list={["toc-row", { "is-current": entry.isCurrent }]}
                  aria-current={entry.isCurrent ? "page" : undefined}
                  data-post-path={entry.href}
                >
                  <span class="toc-row-title">{entry.title}</span>
                  <span class="read-mark" title="看過了" aria-label="已閱讀">
                    ✓
                  </span>
                </a>
              ))}
            </section>
          ))
        }
      </div>
    </details>
  </div>
</nav>

<script>
  /** Progressive enhancement for the series table of contents. Everything
   *  essential (open, close, jump) already works through <details>; this adds
   *  read marks, progress, Esc-to-close and scrolling to the current entry. */
  function initSeriesNav() {
    const nav = document.querySelector<HTMLElement>("[data-series-nav]");
    if (!nav) return;

    const details = nav.querySelector<HTMLDetailsElement>("[data-series-toc]");
    if (!details) return;

    let read: string[] = [];
    try {
      read = JSON.parse(localStorage.getItem("readPosts") ?? "[]");
    } catch {
      read = [];
    }

    // Read marks + progress. Silently skipped when storage is unavailable.
    if (read.length > 0) {
      let done = 0;
      nav.querySelectorAll<HTMLElement>("[data-post-path]").forEach(row => {
        if (!read.includes(row.dataset.postPath ?? "")) return;
        done += 1;
        row.querySelector(".read-mark")?.classList.add("is-read");
      });

      const total = Number(nav.dataset.total ?? "0");
      const progress = nav.querySelector<HTMLElement>("[data-series-progress]");
      // Just the count — the bar already shows "13 / 38" for position, and a
      // second x/y right next to it reads as the same number twice.
      if (progress && total > 0 && done > 0) {
        progress.textContent = `✓ ${done}`;
        progress.hidden = false;
      }
    }

    details.addEventListener("toggle", () => {
      if (!details.open) return;
      // Land on the chapter being read rather than the top of a 38-item list.
      details
        .querySelector(".toc-row.is-current")
        ?.scrollIntoView({ block: "center" });
    });

    document.addEventListener("keydown", e => {
      if (e.key === "Escape" && details.open) {
        details.open = false;
        details.querySelector<HTMLElement>(".toc-button")?.focus();
      }
    });
  }

  document.addEventListener("astro:page-load", initSeriesNav);
</script>

<style>
  .series-nav {
    margin-bottom: 1rem;
  }

  .series-bar {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--surface);
    font-family: var(--font-cartograph), monospace;
    font-size: 0.8rem;
  }

  .series-home {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    color: var(--foreground);
    font-weight: 600;
    transition: color 0.15s ease;
  }
  .series-home:hover {
    color: var(--accent);
  }
  .series-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
    color: var(--accent);
  }
  .series-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .series-part {
    color: var(--ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .series-part::before {
    content: "›";
    margin-right: 0.5rem;
    color: var(--ink-faint);
  }

  .series-pos {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
  }
  .series-pos-sep {
    color: var(--ink-faint);
  }

  /* ─── Table of contents ─── */
  .series-toc {
    position: relative;
    flex-shrink: 0;
  }

  .toc-button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 999px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--ink-secondary);
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .toc-button::-webkit-details-marker {
    display: none;
  }
  .toc-button:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }
  .toc-button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .toc-icon {
    width: 0.8rem;
    height: 0.8rem;
  }
  .toc-close-label {
    display: none;
  }
  .series-toc[open] > .toc-button .toc-open-label {
    display: none;
  }
  .series-toc[open] > .toc-button .toc-close-label {
    display: inline;
  }
  .series-toc[open] > .toc-button {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 9%, transparent);
  }
  .toc-progress {
    padding-left: 0.35rem;
    margin-left: 0.1rem;
    border-left: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    color: var(--sticker-green);
    font-variant-numeric: tabular-nums;
  }

  .toc-panel {
    position: absolute;
    z-index: 30;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(24rem, calc(100vw - 2.5rem));
    max-height: min(70vh, 30rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--surface);
    box-shadow: var(--shadow-float);
    text-align: start;
  }

  .toc-part + .toc-part {
    margin-top: 0.35rem;
  }
  .toc-part-title {
    position: sticky;
    top: -0.5rem;
    margin: 0;
    padding: 0.45rem 0.5rem 0.3rem;
    background: var(--surface);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
  }

  .toc-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.4rem;
    font-family: var(--font-app);
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--ink-secondary);
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .toc-row:hover {
    background: color-mix(in srgb, var(--accent) 7%, transparent);
    color: var(--accent);
  }
  .toc-row-title {
    flex: 1;
    min-width: 0;
  }
  .toc-row.is-current {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    font-weight: 600;
  }
  .toc-landing {
    font-weight: 600;
    color: var(--foreground);
  }

  .read-mark {
    flex-shrink: 0;
    display: none;
    font-size: 0.72rem;
    color: var(--sticker-green);
  }
  .read-mark.is-read {
    display: inline;
  }

  /* Narrow screens: drop the part name, and anchor the panel to the whole bar
     instead of the button so it spans the full width without overflowing. */
  @media (max-width: 30rem) {
    .series-part {
      display: none;
    }
    .series-toc {
      position: static;
    }
    .toc-panel {
      left: 0;
      right: 0;
      width: auto;
    }
  }
</style>
