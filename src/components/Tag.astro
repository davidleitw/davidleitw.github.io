---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "flex items-center gap-1 rounded-full border border-border bg-surface font-medium text-ink-secondary",
      "transition-all duration-200",
      "hover:-translate-y-0.5 hover:border-accent/40 hover:text-accent hover:shadow-(--shadow-card)",
      "focus-visible:text-accent",
      { "px-2.5 py-0.5 text-xs": size === "sm" },
      { "px-3.5 py-1 text-sm": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-60",
        { "size-4": size === "lg" },
        { "size-3.5": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
