---
import type { RecentEntry } from "@/utils/postSeries";
import Datetime from "@/components/Datetime.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

type Props = {
  entries: RecentEntry[];
};

const { entries } = Astro.props;
---

<section class="bento-card flex h-full flex-col" aria-label="最新文章">
  <div class="mb-3 flex items-center justify-between">
    <h2 class="text-sm font-semibold tracking-tight">最新文章</h2>
    <a
      href="/posts"
      class="group inline-flex items-center gap-1 text-xs font-medium text-accent hover:underline"
    >
      全部
      <IconArrowRight
        class="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5"
      />
    </a>
  </div>

  <ul class="flex flex-1 flex-col">
    {
      entries.map(entry => (
        <li class="border-b border-border/60 last:border-b-0">
          <a
            href={entry.href}
            class="latest-row group block rounded-lg px-2 py-2.5 transition-colors hover:bg-background"
            data-post-path={entry.kind === "post" ? entry.href : undefined}
          >
            <div class="flex items-start justify-between gap-3">
              <p class="line-clamp-1 flex items-center gap-1.5 text-sm font-medium text-ink-secondary transition-colors group-hover:text-accent">
                {entry.kind === "series" && (
                  <span class="latest-series-badge">系列</span>
                )}
                {entry.kind === "series" ? entry.name : entry.title}
              </p>
              {entry.kind === "series" ? (
                <span class="mt-0.5 shrink-0 text-xs font-medium text-accent">
                  {entry.count} 篇
                </span>
              ) : (
                <span
                  class="read-mark mt-0.5 hidden shrink-0 text-xs text-sticker-green"
                  title="看過了"
                  aria-label="已閱讀"
                >
                  ✓
                </span>
              )}
            </div>
            <div class="mt-1 flex items-center gap-2">
              <Datetime
                pubDatetime={entry.date}
                class="shrink-0 text-xs text-ink-faint [&>svg]:hidden"
              />
              <p class="line-clamp-1 text-xs text-ink-muted">
                {entry.kind === "series" ? "整個系列 · 從頭讀起" : entry.description}
              </p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .latest-series-badge {
    flex-shrink: 0;
    font-family: var(--font-cartograph), monospace;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--accent);
    padding: 0.05rem 0.35rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
</style>

<script>
  // Mark posts the visitor has already opened (written by the post page).
  function applyReadMarks() {
    let read: string[] = [];
    try {
      read = JSON.parse(localStorage.getItem("readPosts") ?? "[]");
    } catch {
      read = [];
    }
    if (read.length === 0) return;
    document.querySelectorAll<HTMLElement>("[data-post-path]").forEach(link => {
      if (read.includes(link.dataset.postPath ?? "")) {
        link.querySelector(".read-mark")?.classList.remove("hidden");
      }
    });
  }
  document.addEventListener("astro:page-load", applyReadMarks);
</script>
