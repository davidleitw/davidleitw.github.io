---
// Photo-collage strip. Renders nothing until mascot scene images exist.
import { Image } from "astro:assets";

const mascots = import.meta.glob<{ default: ImageMetadata }>(
  "@/assets/mascot/*.png",
  { eager: true }
);

const scenes = [
  { img: mascots["/src/assets/mascot/mascot-coding.png"]?.default, alt: "小貓在筆電前寫程式", caption: "debug 中" },
  { img: mascots["/src/assets/mascot/mascot-polaroid.png"]?.default, alt: "小貓的拍立得生活照", caption: "日常" },
  { img: mascots["/src/assets/mascot/mascot-sleep.png"]?.default, alt: "小貓睡著了", caption: "充電中" },
].filter(scene => scene.img);
---

{
  scenes.length > 0 && (
    <section class="bento-card flex h-full items-center justify-center gap-4" aria-label="生活照拼貼">
      {scenes.map((scene, i) => (
        <figure
          class:list={[
            "collage-photo shrink-0 rounded-lg border border-border bg-surface p-2 pb-1 shadow-(--shadow-card)",
            i % 2 === 0 ? "-rotate-2" : "rotate-2",
          ]}
        >
          <Image
            src={scene.img!}
            alt={scene.alt}
            width={280}
            height={210}
            class="h-24 w-32 rounded-md bg-background object-cover sm:h-28 sm:w-36"
          />
          <figcaption class="pt-1 text-center font-cartograph text-[10px] text-ink-faint">
            {scene.caption}
          </figcaption>
        </figure>
      ))}
    </section>
  )
}

<style>
  .collage-photo {
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .collage-photo:hover {
    transform: rotate(0deg) translateY(-4px) scale(1.04);
  }
</style>
