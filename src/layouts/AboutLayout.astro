---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <div class="mb-8 rounded-2xl border border-border bg-surface px-6 py-8 shadow-(--shadow-card) sm:px-10 sm:py-10">
      <p class="text-sm text-ink-muted">Hey, I'm</p>
      <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">
        {SITE.author}
      </h1>
      <p class="mt-3 max-w-xl text-ink-secondary">{SITE.desc}</p>
    </div>

    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
